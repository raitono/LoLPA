{
  "name": "lolpa",
  "version": "0.0.0",
  "description": "League of Legends Performance Analyzer",
  "keywords": [
    "loopback-application",
    "loopback"
  ],
  "main": "index.js",
  "engines": {
    "node": ">=8.9"
  },
  "scripts": {
    "build:apidocs": "lb-apidocs",
    "build": "lb-tsc es2017 --outDir dist",
    "build:watch": "lb-tsc --watch",
    "clean": "lb-clean dist",
    "lint": "npm run prettier:check && npm run tslint",
    "lint:fix": "npm run tslint:fix && npm run prettier:fix",
    "prettier:cli": "lb-prettier \"**/*.ts\" \"**/*.js\"",
    "prettier:check": "npm run prettier:cli -- -l",
    "prettier:fix": "npm run prettier:cli -- --write",
    "tslint": "lb-tslint",
    "tslint:fix": "npm run tslint -- --fix",
    "pretest": "npm run clean && npm run build",
    "test": "lb-mocha --allow-console-logs \"dist/test\"",
    "posttest": "npm run lint",
    "test:dev": "lb-mocha --allow-console-logs dist/test/**/*.js && npm run posttest",
    "prestart": "npm run build",
    "start": "nodemon .",
    "prepublishOnly": "npm run test"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/raitono/LoLPA"
  },
  "bugs": {
    "url": "https://github.com/raitono/LoLPA/issues"
  },
  "author": "Ben Painter <bpaintx2@gmail.com>",
  "license": "UNLICENSED",
  "files": [
    "README.md",
    "index.js",
    "index.d.ts",
    "dist/src",
    "dist/index*",
    "src"
  ],
  "dependencies": {
    "@loopback/boot": "^1.0.5",
    "@loopback/context": "^1.1.0",
    "@loopback/core": "^1.1.0",
    "@loopback/openapi-v3": "^1.1.2",
    "@loopback/repository": "^1.0.5",
    "@loopback/rest": "^1.3.1",
    "@loopback/rest-explorer": "^1.1.1",
    "@loopback/service-proxy": "^1.0.2",
    "kayn": "^0.8.26",
    "dotenv-safe": "^6.1.0"
  },
  "devDependencies": {
    "@loopback/build": "^1.0.1",
    "@loopback/testlab": "^1.0.1",
    "@types/node": "^10.11.2",
    "nodemon": "^1.18.6"
  }
}
