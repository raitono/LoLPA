{
  "name": "lolpa",
  "version": "0.0.0",
  "description": "League of Legends Performance Analyzer",
  "main": "out/server.js",
  "engines": {
    "node": ">=10"
  },
  "scripts": {
    "prebuild": "rm -rf out/",
    "build": "tsc",
    "build:watch": "npm run prebuild && tsc -w",
    "test": "nyc ava",
    "start": "node out/server.js",
    "start:watch": "nodemon out/server.js",
    "dev": "npm run start:watch"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/raitono/LoLPA"
  },
  "bugs": {
    "url": "https://github.com/raitono/LoLPA/issues"
  },
  "author": "Ben Painter <bpaintx2@gmail.com>",
  "license": "MIT",
  "eslintConfig": {
    "extends": "plugin:ava/recommended"
  },
  "dependencies": {
    "debug": "^4.1.0",
    "dotenv-safe": "^6.1.0",
    "http-status-codes": "^1.3.2",
    "kayn": "^0.9.8",
    "knex": "^0.16.5",
    "koa": "^2.7.0",
    "koa-bodyparser": "^4.2.1",
    "koa-json": "^2.0.2",
    "koa-router": "^7.4.0",
    "mysql2": "^1.6.5",
    "objection": "^1.6.7",
    "supports-color": "^6.0.0"
  },
  "devDependencies": {
    "@types/dotenv-safe": "^5.0.2",
    "@types/http-status-codes": "^1.2.0",
    "@types/koa": "^2.0.48",
    "@types/koa-bodyparser": "^4.2.2",
    "@types/koa-json": "^2.0.18",
    "@types/koa-router": "^7.0.40",
    "@types/node": "^10.11.2",
    "@types/supertest": "^2.0.7",
    "ava": "^1.4.1",
    "eslint": "^5.16.0",
    "eslint-plugin-ava": "^6.0.0",
    "nodemon": "^1.18.11",
    "nyc": "^14.0.0",
    "supertest": "^4.0.2",
    "tslint": "^5.15.0",
    "tslint-config-airbnb": "^5.11.1",
    "typescript": "^3.4.3"
  }
}
